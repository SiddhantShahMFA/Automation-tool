generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Workspace & Credentials ───────────────────────────────────────

model WorkspaceSettings {
  id                 String   @id @default("default")
  companyName        String?
  setupCompleted     Boolean  @default(false)
  notionDatabaseId   String?
  notionDatabaseName String?
  jiraProjectKey     String?
  prdTemplatePrefs   Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("workspace_settings")
}

model IntegrationCredential {
  id              String   @id @default(cuid())
  type            String // "notion" | "model" | "jira"
  encryptedConfig String // AES-256-GCM encrypted JSON
  maskedDisplay   String // e.g. "sk-...abc3"
  isValid         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([type])
  @@map("integration_credentials")
}

// ─── Projects & PRDs ───────────────────────────────────────────────

model Project {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("active") // active | archived
  jiraProjectKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prdDocuments       PrdDocument[]
  generationSessions GenerationSession[]

  @@map("projects")
}

model PrdDocument {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  notionPageId  String?  @unique
  notionPageUrl String?
  version       Int      @default(1)
  status        String   @default("draft") // draft | published | updating
  title         String?
  contentJson   Json? // Structured PRD content
  sourceSummary String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generatedArtifacts GeneratedArtifact[]
  backgroundJobs     BackgroundJob[]
  updateLogs         PrdUpdateLog[]
  requirements       PrdRequirement[]
  requirementChanges RequirementChange[]
  jiraTickets        JiraTicket[]
  artifactVersions   ArtifactVersion[]

  @@map("prd_documents")
}

// ─── Generation Sessions ───────────────────────────────────────────

model GenerationSession {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  type      String // "create" | "update"
  status    String   @default("pending") // pending | clarifying | generating | completed | failed
  rawInput  String   @db.Text
  aiContext Json? // Accumulated AI context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clarificationQuestions ClarificationQuestion[]
  generatedArtifacts     GeneratedArtifact[]

  @@map("generation_sessions")
}

model ClarificationQuestion {
  id        String            @id @default(cuid())
  sessionId String
  session   GenerationSession @relation(fields: [sessionId], references: [id])
  question  String            @db.Text
  answer    String?           @db.Text
  orderNum  Int
  required  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("clarification_questions")
}

// ─── Generated Artifacts ───────────────────────────────────────────

model GeneratedArtifact {
  id            String             @id @default(cuid())
  sessionId     String?
  session       GenerationSession? @relation(fields: [sessionId], references: [id])
  prdDocumentId String?
  prdDocument   PrdDocument?       @relation(fields: [prdDocumentId], references: [id])
  type          String // "prd_draft" | "plan_md" | "jira_tickets"
  contentJson   Json // Full artifact content
  createdAt     DateTime           @default(now())

  @@map("generated_artifacts")
}

// ─── Canonical PRD Requirements ────────────────────────────────────

model PrdRequirement {
  id            String   @id @default(cuid())
  prdDocumentId String
  prdDocument   PrdDocument @relation(fields: [prdDocumentId], references: [id])
  stableKey     String
  category      String // "functional" | "non_functional"
  displayId     String?
  title         String
  description   String   @db.Text
  priority      String?
  status        String   @default("active") // active | removed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions   RequirementVersion[]
  changes    RequirementChange[]
  jiraLinks  JiraTicketRequirementLink[]

  @@unique([prdDocumentId, stableKey])
  @@map("prd_requirements")
}

model RequirementVersion {
  id            String   @id @default(cuid())
  requirementId String
  requirement   PrdRequirement @relation(fields: [requirementId], references: [id])
  prdVersion    Int
  title         String
  description   String   @db.Text
  priority      String?
  snapshotJson  Json
  createdAt     DateTime @default(now())

  newChanges RequirementChange[] @relation("RequirementChangeNewVersion")
  oldChanges RequirementChange[] @relation("RequirementChangeOldVersion")

  @@map("requirement_versions")
}

model RequirementChange {
  id              String   @id @default(cuid())
  prdDocumentId   String
  prdDocument     PrdDocument @relation(fields: [prdDocumentId], references: [id])
  requirementId   String
  requirement     PrdRequirement @relation(fields: [requirementId], references: [id])
  prdVersion      Int
  changeType      String // ADD | UPDATE | REMOVE
  summary         String   @db.Text
  oldVersionId    String?
  oldVersion      RequirementVersion? @relation("RequirementChangeOldVersion", fields: [oldVersionId], references: [id])
  newVersionId    String?
  newVersion      RequirementVersion? @relation("RequirementChangeNewVersion", fields: [newVersionId], references: [id])
  createdAt       DateTime @default(now())

  @@map("requirement_changes")
}

// ─── Jira Canonical State ──────────────────────────────────────────

model JiraTicket {
  id              String   @id @default(cuid())
  prdDocumentId   String
  prdDocument     PrdDocument @relation(fields: [prdDocumentId], references: [id])
  projectKey      String?
  issueKey        String?
  type            String // Epic | Story
  summary         String
  description     String   @db.Text
  status          String   @default("draft") // draft | published | close_recommended
  lastAction      String   @default("CREATE") // CREATE | UPDATE | KEEP | CLOSE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requirementLinks JiraTicketRequirementLink[]

  @@map("jira_tickets")
}

model JiraTicketRequirementLink {
  id            String   @id @default(cuid())
  jiraTicketId   String
  jiraTicket     JiraTicket @relation(fields: [jiraTicketId], references: [id])
  requirementId  String
  requirement    PrdRequirement @relation(fields: [requirementId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([jiraTicketId, requirementId])
  @@map("jira_ticket_requirement_links")
}

// ─── Artifact Versioning ───────────────────────────────────────────

model ArtifactVersion {
  id                String   @id @default(cuid())
  prdDocumentId     String
  prdDocument       PrdDocument @relation(fields: [prdDocumentId], references: [id])
  type              String // prd_content | plan_md | jira_delta | jira_publish | notion_publish | backfill
  prdVersion        Int
  status            String   @default("draft")
  sourceArtifactId  String?
  payloadJson       Json
  createdAt         DateTime @default(now())

  @@map("artifact_versions")
}

// ─── Background Jobs ───────────────────────────────────────────────

model BackgroundJob {
  id             String       @id @default(cuid())
  type           String // "generate_prd" | "publish_notion" | "generate_jira" | "generate_plan"
  status         String       @default("pending") // pending | running | completed | failed | retrying
  payload        Json
  result         Json?
  error          String?      @db.Text
  retries        Int          @default(0)
  maxRetries     Int          @default(3)
  idempotencyKey String?      @unique
  prdDocumentId  String?
  prdDocument    PrdDocument? @relation(fields: [prdDocumentId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime @updatedAt
  startedAt      DateTime?
  completedAt    DateTime?

  @@map("background_jobs")
}

// ─── PRD Update Logs ───────────────────────────────────────────────

model PrdUpdateLog {
  id              String      @id @default(cuid())
  prdDocumentId   String
  prdDocument     PrdDocument @relation(fields: [prdDocumentId], references: [id])
  previousContent Json?
  newContent      Json?
  changesSummary  String?     @db.Text
  createdAt       DateTime    @default(now())

  @@map("prd_update_logs")
}

// ─── Audit Events ──────────────────────────────────────────────────

model AuditEvent {
  id         String   @id @default(cuid())
  action     String // "setup_completed" | "prd_created" | "prd_published" | etc.
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("audit_events")
}
